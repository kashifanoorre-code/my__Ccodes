#include<stdio.h>
int power(int x,int y){
    if(y==0){
        return 1;
    }
    else{
        return x*power(x,y-1);
    }
}
int main(){
   int x,y,i;
   printf("enter first number: ");
   scanf("%d",&x);
   printf("enter power: ");
   scanf("%d",&y);
   
   int result=power(x,y);
   printf("%d",result);
    return 0;
}
