#include<stdio.h>
int main(){
    int length,element;
    printf("enter length of array: ");
    scanf("%d",&length);
    int arr[length];
    for(int i=0;i<length;i++){
        printf("enter element of array: ");
        scanf("%d",&element);
        arr[i]=element;
    }
    for(int i=0;i<length;i++){
        printf("%d ",arr[i]);
    }
    int max=arr[0];
    for(int i=0;i<length;i++){
      if(arr[i]>max){
          max=arr[i];
      }
    }
    printf("%d",max);
    
    
    return 0;
}
