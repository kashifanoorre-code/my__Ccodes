#include<stdio.h>
int main(){
    int element,key,flag,length,found=0;
    printf("enter length of your array:");
    scanf("%d",&length);
    int arr[length];
    for(int i=0;i<length;i++){
        printf("enter element:");
        scanf("%d",&element);
        arr[i]=element;
    }
    printf("enter element to search:");
    scanf("%d",&key);
    for(int i=0;i<length;i++){
        if(arr[i]==key){
            printf("element found at index %d ",i);
            found=1;
            break;
        }
       
    }
    if(found==0){
        printf("element not found :(");
    }
    
    return 0;
}
