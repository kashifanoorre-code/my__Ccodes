#include <stdio.h>
void matrix_c(int rows,int A[rows][rows],int B[rows][rows]){
    printf("matrix C is\n");
    for(int i=0;i<rows;i++){
        for(int j=0;j<rows;j++){
            printf("[%d]",A[i][j]+B[i][j]);
        }
        printf("\n");
    }
    
}

int main() {
    int i,j,rows;
    printf("enter number of rows: ");
    scanf("%d",&rows);
    int A[rows][rows];
    
    for(i=0;i<rows;i++){
        for(j=0;j<rows;j++){
            printf("enter your element: ");
            scanf("%d",&A[i][j]);
        }
        printf("\n");
    }
    
    int B[rows][rows];
    for(i=0;i<rows;i++){
        for(j=0;j<rows;j++){
            printf("enter your element: ");
            scanf("%d",&B[i][j]);
        }
        printf("\n");
    }
    
    printf("matrix A is:\n");
    for(i=0;i<rows;i++){
        for(j=0;j<rows;j++){
            printf("[%d]",A[i][j]);
        }
        printf("\n");
    }  
    
    printf("matrix B is:\n");
    for(i=0;i<rows;i++){
        for(j=0;j<rows;j++){
            printf("[%d]",B[i][j]);
        }
        printf("\n");
    }
    
    matrix_c(rows,A,B);
    return 0;
}
