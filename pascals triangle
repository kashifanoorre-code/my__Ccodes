#include <stdio.h>

int main() {
    int i,j,num,n;
    printf("enter number of rows: ");
    scanf("%d",&n);
    
    for(i=0;i<n;i++){
        num=1;
        for(int space = 0; space < n - i - 1; space++)
            printf("  ");
        for(j=0;j<=i;j++){
            printf("%4d ",num);
            num=num*(i-j)/(j+1);
        }
        printf("\n");
    }

    return 0;
}
