#include<stdio.h>
int linear_search(int arr[],int length, int key){
    int found=0;
    for(int i=0;i<length;i++){
        if (arr[i]==key){
            return found=1;
        }
    }
    return found=0;
}
    

int main(){
    int element,key,length,result;
    printf("enter length of your array:");
    scanf("%d",&length);
    
    printf("enter your search element:");
    scanf("%d",&key);
    
    int arr[length];
    
    for(int i=0;i<length;i++){
        printf("enter element:");
        scanf("%d",&element);
        arr[i]=element;
    }
    result=linear_search(arr,length,key);
    if (result==1){
        printf("search element found ");
    }
    else{
        printf("search element not found ");
    }
    return 0;
}
